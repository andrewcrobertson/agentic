{
  "name": "@agentic/api",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "vite build",
    "dev": "node --watch dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@agentic/eslint": "workspace:*",
    "@agentic/prettier": "workspace:*",
    "@agentic/system.logging": "workspace:*",
    "@agentic/typescript": "workspace:*",
    "@tsconfig/recommended": "^1.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "prettier": "@agentic/prettier"
}
